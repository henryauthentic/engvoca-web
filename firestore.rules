rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superadmin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "editor"
      );
    }

    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      // Leaderboard: cho phep user login doc TAT CA users
      allow read: if request.auth != null;
      
      // User tu tao tai khoan
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Update: User tu update HOAC Admin update (chi dinh field)
      allow update: if (request.auth != null && request.auth.uid == userId)
        || (isAdmin() && request.resource.data.diff(resource.data).changedKeys().hasOnly([
             'role',
             'currentStreak',
             'longestStreak',
             'learnedWords',
             'totalXp',
             'totalReviews',
             'totalLapses',
             'topicProgress',
             'premium',
             'lastSyncedAt',
             'lastChangeSource',
             'isBanned',
             'dailyGoal',
             'learningLevel',
             'forceSyncRequested'
           ]));
      
      // Subcollections: wordProgress, badges, studyTimeHistory, practiceHistory, savedWords, quizResults
      match /{subcollection}/{docId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }
    }

    // ==========================================
    // CORE CONTENT (Topics & Words)
    // ==========================================
    match /topics/{topicId} {
      // Public read (ai cung duoc doc)
      allow read: if true;
      // Chi Admin duoc them/sua/xoa
      allow create, update, delete: if isAdmin();
    }
    
    match /words/{wordId} {
      // Public read (ai cung duoc doc)
      allow read: if true;
      // Chi Admin duoc them/sua/xoa
      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // ADMIN RESOURCES
    // ==========================================
    
    // Admin Logs (Immutable)
    match /adminLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false; // Khong ai duoc sua/xoa log
    }

    // Analytics Dashboard
    match /analytics/{doc=**} {
      allow read, write: if isAdmin();
    }

    // System Settings & Content Version
    match /system/{doc} {
      allow read: if request.auth != null; // Mobile App can doc contentVersion
      allow write: if isAdmin();
    }

    // ==========================================
    // NEW MODULES
    // ==========================================

    // Feature Flags & Config
    match /config/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Release History (Publish Pipeline)
    match /releases/{releaseId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Immutable release records
    }

    // Announcements
    match /announcements/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Feedback & Support
    match /feedback/{docId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }
  }
}
